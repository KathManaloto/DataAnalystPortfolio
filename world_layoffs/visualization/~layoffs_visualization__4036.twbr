    <edit-parameter-action caption='ParameterColorEnd1' name='[Action3_0C3E394A69984EA5ADC20ACDFBEE2B2C]'>
      <activation type='on-select' />
      <source type='sheet' worksheet='Industry Treemap' />
      <agg-type type='max' />
      <clear-option type='do-nothing' value='i:1' />
      <params>
