      <group caption='Top 10 Industry Set' name='[Top Industries]' name-style='unqualified' user:ui-builder='filter-group'>
        <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
          <groupfilter direction='DESC' expression='SUM([total_laid_off])' function='order' user:ui-marker='order'>
