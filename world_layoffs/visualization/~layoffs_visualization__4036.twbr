    <worksheet name='Yearly Trend'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Semibold' fontsize='12'>Total Layoffs by Year </run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Regular' fontsize='8'>March 2020 – February 2026</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='layoffs_tableau' name='federated.031x1na1u2kpsv1e86a431uysb48' />
          </datasources>
          <datasource-dependencies datasource='federated.031x1na1u2kpsv1e86a431uysb48'>
            <column caption='2023 Highlight Color' datatype='string' name='[Calculation_0912913982398465]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([date]) = 2023 THEN &quot;Highlight&quot; ELSE &quot;Normal&quot; END' />
            </column>
            <column caption='2023 Highlight Circle Size' datatype='integer' name='[Calculation_0912913984827394]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([date]) = 2023 THEN 2 ELSE 1 END' />
            </column>
            <column caption='Yearly Summary' datatype='string' name='[Calculation_0912913987076099]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE YEAR([date])&#13;&#10;    WHEN 2020 THEN &quot;▶ REMARKS: Start of dataset (Mar 2020, COVID onset)&quot;&#13;&#10;    WHEN 2021 THEN &quot;▶ REMARKS: Big drop: -80% from 2020&quot;&#13;&#10;    WHEN 2022 THEN &quot;▶ REMARKS: Huge increase: +938% from 2021&quot;&#13;&#10;    WHEN 2023 THEN &quot;▶ REMARKS: Peak layoffs&quot; &#13;&#10;    WHEN 2024 THEN &quot;▶ REMARKS: Layoffs gradually declining&quot;&#13;&#10;    WHEN 2025 THEN &quot;▶ REMARKS: Layoffs gradually declining&quot;&#13;&#10;    WHEN 2026 THEN &quot;▶ REMARKS: End of dataset (Feb 2026)&quot;&#13;&#10;    ELSE &quot;&quot;&#13;&#10;END' />
            </column>
            <column caption='2023 Top Industry' datatype='string' name='[Calculation_0912914014396420]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([date]) = 2023 &#13;&#10;THEN &quot;▶ TOP INDUSTRIES: Other, Retail, Consumer&quot; &#13;&#10;ELSE NULL &#13;&#10;END' />
            </column>
            <column caption='2023 Peak Month' datatype='string' name='[Calculation_0912914021548037]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([date]) = 2023 &#13;&#10;THEN &quot;▶ PEAK MONTH: January (33.9% of total 2023 layoffs)&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END' />
            </column>
            <column caption='Industry (Dynamic Grouping)' datatype='string' name='[Calculation_0912914052628487]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Top Industries] &#13;&#10;THEN [industry] &#13;&#10;ELSE &quot;All Other Industries&quot; &#13;&#10;END' />
            </column>
            <column-instance column='[Calculation_0912913984827394]' derivation='Attribute' name='[attr:Calculation_0912913984827394:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0912913987076099]' derivation='Attribute' name='[attr:Calculation_0912913987076099:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0912914014396420]' derivation='Attribute' name='[attr:Calculation_0912914014396420:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0912914021548037]' derivation='Attribute' name='[attr:Calculation_0912914021548037:nk]' pivot='key' type='nominal' />
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Industry' datatype='string' name='[industry]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0912913982398465]' derivation='None' name='[none:Calculation_0912913982398465:nk]' pivot='key' type='nominal' />
            <column-instance column='[total_laid_off]' derivation='Sum' name='[sum:total_laid_off:qk]' pivot='key' type='quantitative' />
            <column caption='Total Laid Off' datatype='integer' name='[total_laid_off]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='Year' name='[yr:date:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.031x1na1u2kpsv1e86a431uysb48].[Action (Industry (Dynamic Grouping))]'>
            <groupfilter function='level-members' level='[Calculation_0912914052628487]' user:ui-action-filter='[Action2_B6F6F0107CEF4610ABEC61BCC01CF58B]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.031x1na1u2kpsv1e86a431uysb48].[Action (Industry (Dynamic Grouping))]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='1' field='[federated.031x1na1u2kpsv1e86a431uysb48].[sum:total_laid_off:qk]' field-type='quantitative' fold='true' max='354658' min='-85154' range-type='fixed' scope='rows' synchronized='true' type='space' />
