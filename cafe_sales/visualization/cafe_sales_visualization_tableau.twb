      <aliases enabled='yes' />
      <column caption='Avg Transaction Value' datatype='real' default-format='c&quot;$&quot;#,##0.00;(&quot;$&quot;#,##0.00)' name='[Calculation_0392298665205760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent]) / SUM([Quantity])' />
      </column>
      <column caption='Peak Reference' datatype='integer' name='[Calculation_0398345642631174]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Quantity]) = WINDOW_MAX(SUM([Quantity])) &#13;&#10;THEN SUM([Quantity]) &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Peak Revenue' datatype='integer' name='[Calculation_0398345676832776]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IF SUM([Total Spent]) = WINDOW_MAX(SUM([Total Spent])) THEN 3&#13;&#10;ELSEIF SUM([Total Spent]) = WINDOW_MIN(SUM([Total Spent])) THEN 1&#13;&#10;ELSE 2&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Item Remarks' datatype='string' name='[Calculation_1051181072068608]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Item]     &#13;&#10;    WHEN &quot;Salad&quot; THEN &quot;Revenue Driver&quot; &#13;&#10;    WHEN &quot;Coffee&quot; THEN &quot;Volume Driver&quot;&#13;&#10;    WHEN &quot;Unknown Item&quot; THEN &quot; Items that could not be uniquely identified were labeled as &apos;Unknown Item&apos; to avoid misrepresenting product-specific sales trends.&quot;&#13;&#10;    ELSE &quot;-&quot;&#13;&#10;END' />
      </column>
      <column caption='Revenue Rank' datatype='integer' name='[Calculation_1051181074042881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Total Spent]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Quantity Rank' datatype='integer' name='[Calculation_1051181074161666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Quantity]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Location (Cleaned)' datatype='string' name='[Calculation_1051181082574851]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL([Location], &quot;Not Recorded&quot;)' />
      </column>
      <column caption='Payment Method (Cleaned)' datatype='string' name='[Calculation_1051181083295748]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL([Payment Method], &quot;Not Recorded&quot;)' />
      </column>
      <column caption='Buffer Revenue Max' datatype='real' name='[Calculation_1051181148499979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(SUM([Total Spent])) * 1.4'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Buffer Quantity Max' datatype='real' name='[Calculation_1051181150421004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(SUM([Quantity])) * 1.10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Dynamic Max/Min' datatype='string' name='[Calculation_1051181172256781]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Total Spent]) = WINDOW_MAX(SUM([Total Spent])) THEN &#13;&#10;    &quot;Max: &quot; + &quot;$&quot; + STR(ROUND(SUM([Total Spent]), 0))&#13;&#10;ELSEIF SUM([Total Spent]) = WINDOW_MIN(SUM([Total Spent])) THEN &#13;&#10;    &quot;Min: &quot; + &quot;$&quot; + STR(ROUND(SUM([Total Spent]), 0))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Buffer Revenue Min' datatype='real' name='[Calculation_1051181175283726]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MIN(SUM([Total Spent])) * 0.5'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
