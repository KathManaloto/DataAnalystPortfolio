          <formatted-text>
            <run bold='true' fontname='Tableau Semibold' fontsize='12'>Top 5 Industries by Total Layoffs</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Regular' fontsize='8'>Top 3 Industries = 46% of Total</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Top 3 Industries by Total Layoffs:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Retail</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>, </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Hardware</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>, and </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Other</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>. While </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Retail</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> is the global leader, </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Other</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> was the primary contributor to the 2023 peak.</run>
          </formatted-text>
        </caption>
